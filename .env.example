# ══════════════════════════════════════════════════════════════════════════════
# Tennis Prediction Market Anomaly Scanner — Environment Variables
# Copy this file to .env and fill in your values.
# ══════════════════════════════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────────────────────────────

# Discord webhook URL (Server Settings → Integrations → Webhooks → New Webhook)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL_HERE

# ── Market Providers ──────────────────────────────────────────────────────────

# Polymarket — no API key needed, public REST API
# Set to false to disable this provider entirely
POLYMARKET_ENABLED=true

# Kalshi — requires an API key from https://kalshi.com
# Leave blank to disable Kalshi; set to true + provide key to enable
KALSHI_API_KEY=
KALSHI_ENABLED=false

# ── Anomaly Detection Thresholds ──────────────────────────────────────────────

# Rule 1: LOW_ODDS_SPIKE
# Alert when a player's prior probability was at or below this...
LOW_ODDS_THRESHOLD=0.10
# ...and probability increased by at least this many pp
LOW_ODDS_SPIKE_DELTA=0.03

# Rule 2: FAVORITE_RECOVERY
# Player must have opened at or above this probability
FAVORITE_OPENING_THRESHOLD=0.60
# Player must have fallen to or below this at some point
FAVORITE_LOW_THRESHOLD=0.25
# Current probability must be this far above the recorded low
FAVORITE_RECOVERY_DELTA=0.07

# Rule 3: FAST_MOVE
# Probability increase required within the time window
FAST_MOVE_DELTA=0.05
# Time window in minutes to check for a fast move
FAST_MOVE_WINDOW_MINUTES=10

# Rule 4: NEW_LOW_WATCH
# Alert the first time a player drops below this probability
NEW_LOW_THRESHOLD=0.08

# ── Polling ───────────────────────────────────────────────────────────────────

# Seconds between each full provider sweep
POLL_SECONDS=60

# ── Alert Deduplication ───────────────────────────────────────────────────────

# Minimum minutes between identical alerts (same player, same market, same rule)
ALERT_COOLDOWN_MINUTES=30

# ── Storage ───────────────────────────────────────────────────────────────────

# SQLite database file path (created automatically on first run)
DB_PATH=tennis_scanner.db

# ── Demo / Test Mode ──────────────────────────────────────────────────────────

# Set to true to run with synthetic data — no API keys required.
# Triggers all four anomaly rules within 3 poll cycles.
DEMO_MODE=false
